# --- API ---
PORT=3000
NODE_ENV=development
# 32+ char secret in real envs; dev default below is fine locally
JWT_SECRET=dev-insecure-secret-change-me-please-32+

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- Media storage (dev BlobStore = local filesystem) ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.storage
# Base URL the API serves media/links from
PUBLIC_BASE_URL=http://localhost:3000

# --- Seed admin (created by `pnpm db:seed`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
