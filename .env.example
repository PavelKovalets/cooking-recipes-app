# --- API ---
PORT=3000
NODE_ENV=development
# 32+ char secret in real envs; dev default below is fine locally
JWT_SECRET=dev-insecure-secret-change-me-please-32+

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgres://app:app@localhost:5432/app
# Optional: unpooled URL used only for migrations (managed providers like Neon).
# Local Postgres has no separate pooler, so leave this unset for dev.
# DATABASE_URL_DIRECT=

# --- Media storage ---
# Dev: local filesystem BlobStore (served by the API at /media).
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.storage
# Base URL the API serves media/links from
PUBLIC_BASE_URL=http://localhost:3000

# Prod: S3-compatible bucket (Supabase Storage / Cloudflare R2). Set STORAGE_DRIVER=s3
# and fill these in (required when STORAGE_DRIVER=s3):
# STORAGE_S3_ENDPOINT=https://<ref>.supabase.co/storage/v1/s3
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=recipes-media
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_PUBLIC_BASE_URL=https://<ref>.supabase.co/storage/v1/object/public/recipes-media

# --- Admin account ---
# Local: created by `pnpm db:seed`. Prod: created idempotently by `pnpm --filter @app/api bootstrap`.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
